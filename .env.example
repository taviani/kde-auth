# Server
PORT=3001
ISSUER=http://localhost:3001
COOKIE_SECURE=false
SESSION_TTL_HOURS=24
MIGRATIONS_PATH=migrations

# Postgres credentials (used by docker-compose for db + auth)
POSTGRES_USER=kde_auth
POSTGRES_PASSWORD=kde_auth
POSTGRES_DB=kde_auth

# Local dev only — go run on host connects via published port 5433.
DATABASE_URL=postgres://kde_auth:kde_auth@localhost:5433/kde_auth?sslmode=disable

# Registration
REGISTRATION_OPEN=true

# JWT — dev: leave empty (auto-generated on localhost).
# Production: use PEM files in ./secrets/ (see README).
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY_FILE=
JWT_PUBLIC_KEY_FILE=

# OAuth client seeded on first boot
OAUTH_CLIENT_ID=auth-test
OAUTH_CLIENT_SECRET=dev-secret-change-me-16
OAUTH_CLIENT_NAME=Auth smoke test
OAUTH_REDIRECT_URI=http://localhost:4322/auth/callback

# Email — empty uses log mailer (verification link printed to stdout)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@kde.fr

# Turnstile — empty disables captcha in dev
TURNSTILE_SECRET=
TURNSTILE_SITE_KEY=
